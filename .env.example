# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Smart Contract Addresses (Deploy later)
NEXT_PUBLIC_JOB_MANAGER_ADDRESS=
NEXT_PUBLIC_ESCROW_MANAGER_ADDRESS=
NEXT_PUBLIC_REPUTATION_MANAGER_ADDRESS=

# IPFS Configuration
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
NEXT_PUBLIC_IPFS_API_URL=https://api.pinata.cloud
NEXT_PUBLIC_PINATA_API_KEY=
NEXT_PUBLIC_PINATA_SECRET_KEY=

# Network
NEXT_PUBLIC_DEFAULT_CHAIN_ID=11155111

# Solana RPC Configuration
# Options: 'public' | 'helius' | 'quicknode' | 'alchemy' | 'custom'
NEXT_PUBLIC_RPC_PROVIDER=public

# Helius (recommended for production - https://helius.xyz)
NEXT_PUBLIC_HELIUS_API_KEY=

# QuickNode (https://quicknode.com)
NEXT_PUBLIC_QUICKNODE_RPC_URL=

# Alchemy (https://alchemy.com)
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Custom RPC endpoint (if using NEXT_PUBLIC_RPC_PROVIDER=custom)
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_WS_URL=
NEXT_PUBLIC_RPC_RATE_LIMIT=10

# Google Gemini AI - FREE (for risk assessment feature)
# Get your free key at https://aistudio.google.com (no credit card needed)
# Free tier: 1,500 requests/day, 15 RPM
GEMINI_API_KEY=

# Backend API (Optional)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Hardhat Deployment (for developers)
PRIVATE_KEY=
SEPOLIA_RPC_URL=https://rpc.sepolia.org
ETHERSCAN_API_KEY=
REPORT_GAS=false
