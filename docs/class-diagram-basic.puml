@startuml Freelance Marketplace - Basic Class Diagram

title Freelance Marketplace - Class Diagram

' ========================
' MAIN CLASSES
' ========================

class User {
    + publicKey: PublicKey
    + name: string
    + email: string
    + bio: string
    + avatarUrl: string
    + skills: string[]
    + hourlyRate: number
    + isClient: boolean
    + isFreelancer: boolean
    + createdAt: Date
    --
    + createJob(): Job
    + submitBid(job): Bid
    + getReputation(): Reputation
    + getJobs(): Job[]
}

class Job {
    + id: string
    + title: string
    + description: string
    + budget: number
    + deadline: Date
    + status: string
    + ipfsHash: string
    + createdAt: Date
    --
    + addBid(bid): void
    + selectBid(bid): void
    + complete(): void
    + cancel(): void
}

class Bid {
    + id: string
    + proposedBudget: number
    + estimatedDuration: number
    + coverLetter: string
    + status: string
    + createdAt: Date
    --
    + accept(): void
    + reject(): void
}

class Escrow {
    + id: string
    + amount: number
    + deposited: boolean
    + released: boolean
    + disputed: boolean
    + createdAt: Date
    --
    + deposit(): void
    + release(): void
    + refund(): void
    + openDispute(): void
}

class WorkSubmission {
    + id: string
    + ipfsHash: string
    + description: string
    + submittedAt: Date
    --
    + approve(): void
    + reject(): void
}

class Dispute {
    + id: string
    + reason: string
    + status: string
    + votesClient: number
    + votesFreelancer: number
    + createdAt: Date
    --
    + addVote(forClient): void
    + resolve(): void
}

class Reputation {
    + userId: string
    + totalRating: number
    + reviewCount: number
    + completedJobs: number
    + totalEarned: number
    --
    + getAverageRating(): number
    + addReview(rating): void
}

class Review {
    + id: string
    + rating: number
    + comment: string
    + createdAt: Date
    --
    + edit(): void
    + delete(): void
}

' ========================
' RELATIONSHIPS
' ========================

User "1" -- "0..*" Job : creates >
User "1" -- "0..*" Bid : submits >
User "1" -- "1" Reputation : has >
User "1" -- "0..*" Review : writes >

Job "1" -- "0..*" Bid : receives >
Job "1" -- "0..1" Escrow : has >
Job "1" -- "0..*" Review : receives >

Escrow "1" -- "0..1" WorkSubmission : has >
Escrow "1" -- "0..1" Dispute : may have >

Job -- User : client
Job -- User : freelancer
Bid -- User : bidder
Review -- User : reviewer
Review -- User : reviewee

@enduml
