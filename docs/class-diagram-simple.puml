@startuml Freelance Marketplace - Simple Class Diagram

!define ENTITY_COLOR #E8F5E9
!define SERVICE_COLOR #E3F2FD
!define COMPONENT_COLOR #FFF3E0

title Freelance Marketplace dApp - Complete Class Diagram

' ========================
' DOMAIN ENTITIES
' ========================
package "Domain Entities" ENTITY_COLOR {

    class Job {
        + id: PublicKey
        + title: string
        + description: string
        + budget: number
        + deadline: number
        + client: PublicKey
        + freelancer: PublicKey?
        + status: JobStatus
        + createdAt: number
        + completedAt: number?
        + ipfsHash: string?
        --
        + isOpen(): boolean
        + isCompleted(): boolean
        + canReceiveBids(): boolean
        + assignFreelancer(freelancer): void
        + updateStatus(status): void
        + validate(): boolean
        + toJSON(): object
    }

    class Bid {
        + id: PublicKey
        + job: PublicKey
        + bidder: PublicKey
        + amount: number
        + timeline: number
        + proposal: string
        + status: BidStatus
        + createdAt: number
        --
        + isAccepted(): boolean
        + isPending(): boolean
        + isRejected(): boolean
        + accept(): void
        + reject(): void
        + validate(): boolean
        + toJSON(): object
    }

    class Escrow {
        + id: PublicKey
        + job: PublicKey
        + client: PublicKey
        + freelancer: PublicKey
        + amount: number
        + deposited: boolean
        + released: boolean
        + disputed: boolean
        + createdAt: number
        --
        + canDeposit(): boolean
        + canRelease(): boolean
        + canDispute(): boolean
        + deposit(): void
        + release(): void
        + refund(): void
        + openDispute(): void
        + validate(): boolean
        + toJSON(): object
    }

    class WorkSubmission {
        + id: PublicKey
        + escrow: PublicKey
        + freelancer: PublicKey
        + ipfsHash: string
        + description: string
        + submittedAt: number
        --
        + getIPFSUrl(): string
        + isValid(): boolean
        + toJSON(): object
    }

    class Dispute {
        + id: PublicKey
        + escrow: PublicKey
        + initiator: PublicKey
        + reason: string
        + status: DisputeStatus
        + votesClient: number
        + votesFreelancer: number
        + createdAt: number
        + resolvedAt: number?
        --
        + addVote(voter, forClient): void
        + canResolve(): boolean
        + resolve(): void
        + getWinner(): PublicKey
        + isResolved(): boolean
        + validate(): boolean
        + toJSON(): object
    }

    class VoteRecord {
        + id: PublicKey
        + dispute: PublicKey
        + voter: PublicKey
        + votedForClient: boolean
        + votedAt: number
        --
        + validate(): boolean
        + toJSON(): object
    }

    class Reputation {
        + user: PublicKey
        + totalRating: number
        + reviewCount: number
        + completedJobs: number
        + totalEarned: number
        + createdAt: number
        --
        + getAverageRating(): number
        + addReview(rating): void
        + incrementJobsCompleted(): void
        + addEarnings(amount): void
        + validate(): boolean
        + toJSON(): object
    }

    class Review {
        + id: PublicKey
        + job: PublicKey
        + reviewer: PublicKey
        + reviewee: PublicKey
        + rating: number
        + comment: string
        + createdAt: number
        --
        + isPositive(): boolean
        + validate(): boolean
        + toJSON(): object
    }

    enum JobStatus {
        OPEN
        IN_PROGRESS
        COMPLETED
        DISPUTED
        CANCELLED
    }

    enum BidStatus {
        PENDING
        ACCEPTED
        REJECTED
    }

    enum DisputeStatus {
        OPEN
        RESOLVED_CLIENT
        RESOLVED_FREELANCER
    }
}

' ========================
' SERVICES / HOOKS
' ========================
package "Services (React Hooks)" SERVICE_COLOR {

    class useJobs {
        - program: Program
        - wallet: Wallet
        - connection: Connection
        --
        + createJob(title, description, budget, deadline, ipfsHash): Promise<PublicKey>
        + submitBid(jobId, amount, timeline, proposal): Promise<PublicKey>
        + selectBid(jobId, bidId): Promise<void>
        + fetchJob(jobId): Promise<Job>
        + fetchAllJobs(): Promise<Job[]>
        + fetchJobBids(jobId): Promise<Bid[]>
        + fetchUserJobs(userAddress): Promise<Job[]>
        + cancelJob(jobId): Promise<void>
    }

    class useEscrow {
        - program: Program
        - wallet: Wallet
        - connection: Connection
        --
        + depositEscrow(jobId, amount): Promise<PublicKey>
        + submitWork(escrowId, ipfsHash, description): Promise<PublicKey>
        + releaseEscrow(escrowId): Promise<void>
        + openDispute(escrowId, reason): Promise<PublicKey>
        + voteDispute(disputeId, voteForClient): Promise<void>
        + resolveDispute(disputeId): Promise<void>
        + fetchEscrow(escrowId): Promise<Escrow>
        + fetchDispute(disputeId): Promise<Dispute>
        + fetchWorkSubmission(escrowId): Promise<WorkSubmission>
    }

    class useReputation {
        - program: Program
        - wallet: Wallet
        - connection: Connection
        --
        + initializeReputation(userAddress): Promise<PublicKey>
        + submitReview(jobId, reviewee, rating, comment): Promise<PublicKey>
        + fetchReputation(userAddress): Promise<Reputation>
        + fetchUserReviews(userAddress): Promise<Review[]>
        + hasReputation(userAddress): Promise<boolean>
        + getAverageRating(userAddress): Promise<number>
    }

    class useIPFS {
        - pinataApiKey: string
        - pinataSecretKey: string
        --
        + upload(data): Promise<string>
        + uploadFile(file): Promise<string>
        + fetch(hash): Promise<any>
        + getImageUrl(hash): string
        + uploadJSON(jsonData): Promise<string>
    }

    class useSolanaProgram {
        - connection: Connection
        - wallet: Wallet
        - provider: Provider
        - program: Program
        --
        + getProgram(): Program
        + getProvider(): Provider
        + getConnection(): Connection
        + getWallet(): Wallet
        + getProgramId(): PublicKey
    }

    class useNotifications {
        - notifications: Notification[]
        --
        + addNotification(type, title, message, link): void
        + markAsRead(notificationId): void
        + markAllAsRead(): void
        + deleteNotification(notificationId): void
        + clearAll(): void
        + getUnreadCount(): number
    }
}

' ========================
' UTILITIES
' ========================
package "Utilities" COMPONENT_COLOR {

    class PDADerivation {
        - programId: PublicKey
        --
        + {static} deriveJobPDA(client, jobId): Promise<[PublicKey, number]>
        + {static} deriveBidPDA(job, bidder): Promise<[PublicKey, number]>
        + {static} deriveEscrowPDA(job): Promise<[PublicKey, number]>
        + {static} deriveWorkSubmissionPDA(escrow): Promise<[PublicKey, number]>
        + {static} deriveDisputePDA(escrow): Promise<[PublicKey, number]>
        + {static} deriveVoteRecordPDA(dispute, voter): Promise<[PublicKey, number]>
        + {static} deriveReputationPDA(user): Promise<[PublicKey, number]>
        + {static} deriveReviewPDA(job, reviewer): Promise<[PublicKey, number]>
    }

    class IPFSClient {
        - pinataApiKey: string
        - pinataSecretKey: string
        - pinataBaseUrl: string
        --
        + uploadToIPFS(data): Promise<string>
        + uploadFileToIPFS(file): Promise<string>
        + fetchFromIPFS(hash): Promise<any>
        + getGatewayUrl(hash): string
        + pinJSONToIPFS(jsonData): Promise<string>
    }

    class SolanaHelper {
        --
        + {static} confirmTransaction(connection, signature): Promise<void>
        + {static} getBalance(connection, publicKey): Promise<number>
        + {static} airdrop(connection, publicKey, amount): Promise<void>
        + {static} sendTransaction(connection, transaction, signers): Promise<string>
        + {static} formatPublicKey(publicKey): string
        + {static} shortenAddress(address): string
        + {static} lamportsToSol(lamports): number
        + {static} solToLamports(sol): number
    }

    class DateHelper {
        --
        + {static} formatDate(timestamp): string
        + {static} formatRelativeTime(timestamp): string
        + {static} getTimeRemaining(deadline): string
        + {static} isExpired(deadline): boolean
        + {static} addDays(date, days): number
        + {static} timestampToDate(timestamp): Date
    }
}

' ========================
' COMPONENTS (Selected)
' ========================
package "React Components" COMPONENT_COLOR {

    class JobCard {
        + job: Job
        + onClick: Function
        --
        + render(): JSX.Element
        - handleClick(): void
        - formatBudget(): string
        - getStatusColor(): string
    }

    class BidForm {
        + jobId: PublicKey
        + onSubmit: Function
        --
        + render(): JSX.Element
        - handleSubmit(e): void
        - validateForm(): boolean
        - calculateEstimate(): void
    }

    class EscrowStatus {
        + escrow: Escrow
        + workSubmission: WorkSubmission?
        --
        + render(): JSX.Element
        - getStatusMessage(): string
        - getProgressPercentage(): number
    }

    class DisputeCard {
        + dispute: Dispute
        + onVote: Function
        --
        + render(): JSX.Element
        - handleVote(forClient): void
        - calculateVotePercentage(): number
        - canUserVote(): boolean
    }

    class ProfileCard {
        + reputation: Reputation
        + reviews: Review[]
        --
        + render(): JSX.Element
        - renderRating(): JSX.Element
        - renderStats(): JSX.Element
        - renderReviews(): JSX.Element
    }
}

' ========================
' RELATIONSHIPS
' ========================

' Domain Relationships
Job "1" -- "0..*" Bid : has bids
Job "1" -- "0..1" Escrow : secured by
Escrow "1" -- "0..1" WorkSubmission : has submission
Escrow "1" -- "0..1" Dispute : may have dispute
Dispute "1" -- "0..*" VoteRecord : has votes
Job "1" -- "0..*" Review : receives reviews
Job --> JobStatus
Bid --> BidStatus
Dispute --> DisputeStatus

' Hook Dependencies
useJobs ..> Job : creates/fetches
useJobs ..> Bid : creates/fetches
useEscrow ..> Escrow : manages
useEscrow ..> WorkSubmission : creates/fetches
useEscrow ..> Dispute : manages
useEscrow ..> VoteRecord : creates
useReputation ..> Reputation : manages
useReputation ..> Review : creates/fetches

' Hook Uses Other Hooks
useJobs ..> useSolanaProgram : uses
useEscrow ..> useSolanaProgram : uses
useReputation ..> useSolanaProgram : uses
useJobs ..> useIPFS : uses
useEscrow ..> useIPFS : uses

' Utilities
useJobs ..> PDADerivation : uses
useEscrow ..> PDADerivation : uses
useReputation ..> PDADerivation : uses
useIPFS ..> IPFSClient : uses

' Components Use Hooks
JobCard ..> useJobs : uses
BidForm ..> useJobs : uses
EscrowStatus ..> useEscrow : uses
DisputeCard ..> useEscrow : uses
ProfileCard ..> useReputation : uses

' Components Use Entities
JobCard ..> Job : displays
BidForm ..> Bid : creates
EscrowStatus ..> Escrow : displays
DisputeCard ..> Dispute : displays
ProfileCard ..> Reputation : displays

@enduml
