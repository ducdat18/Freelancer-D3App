@startuml Freelance Marketplace - Class Diagram (Exact)

title Freelance Marketplace - Class Diagram (Theo Code Thực Tế)

' ========================
' MAIN CLASSES (From Smart Contract)
' ========================

class Job {
    + client: PublicKey
    + title: string
    + description: string
    + budget: u64
    + metadata_uri: string
    + status: JobStatus
    + selected_freelancer: Option<PublicKey>
    + created_at: i64
    + updated_at: i64
    + bid_count: u32
    + escrow_amount: u64
    + bump: u8
}

class Bid {
    + job: PublicKey
    + freelancer: PublicKey
    + proposed_budget: u64
    + proposal: string
    + timeline_days: u16
    + status: BidStatus
    + created_at: i64
    + bump: u8
}

class Escrow {
    + job: PublicKey
    + client: PublicKey
    + freelancer: PublicKey
    + amount: u64
    + locked: boolean
    + released: boolean
    + disputed: boolean
    + created_at: i64
    + bump: u8
}

class WorkSubmission {
    + job: PublicKey
    + freelancer: PublicKey
    + deliverable_uri: string
    + submitted_at: i64
    + approved: boolean
    + bump: u8
}

class Dispute {
    + job: PublicKey
    + escrow: PublicKey
    + client: PublicKey
    + freelancer: PublicKey
    + initiator: PublicKey
    + reason: string
    + status: DisputeStatus
    + votes_for_client: u32
    + votes_for_freelancer: u32
    + created_at: i64
    + resolved_at: Option<i64>
    + bump: u8
}

class VoteRecord {
    + dispute: PublicKey
    + voter: PublicKey
    + vote_for_client: boolean
    + voted_at: i64
    + bump: u8
}

class Reputation {
    + user: PublicKey
    + total_reviews: u32
    + average_rating: f32
    + completed_jobs: u32
    + total_earned: u64
    + bump: u8
}

class Review {
    + job: PublicKey
    + reviewer: PublicKey
    + reviewee: PublicKey
    + rating: u8
    + comment: string
    + created_at: i64
    + bump: u8
}

' ========================
' FRONTEND TYPES
' ========================

class UserProfile {
    + address: PublicKey
    + name: string
    + bio: string
    + avatarUrl: string
    + skills: string[]
    + hourlyRate: bigint
    + reputation: Reputation
    + isFreelancer: boolean
    + isClient: boolean
}

' ========================
' ENUMS
' ========================

enum JobStatus {
    Open
    InProgress
    Completed
    Disputed
    Cancelled
}

enum BidStatus {
    Pending
    Accepted
    Rejected
}

enum DisputeStatus {
    Open
    ResolvedClient
    ResolvedFreelancer
}

' ========================
' RELATIONSHIPS
' ========================

' Job relationships
Job "1" -- "0..*" Bid : receives
Job "1" -- "0..1" Escrow : has
Job "1" -- "0..1" WorkSubmission : has
Job "1" -- "0..*" Review : receives
Job -- JobStatus

' Bid relationships
Bid -- BidStatus
Bid --> Job : for
Bid --> UserProfile : from freelancer

' Escrow relationships
Escrow --> Job : secures
Escrow "1" -- "0..1" Dispute : may have

' Dispute relationships
Dispute --> Escrow : about
Dispute "1" -- "0..*" VoteRecord : has votes
Dispute -- DisputeStatus

' WorkSubmission relationships
WorkSubmission --> Job : delivered to

' Reputation & Review relationships
UserProfile "1" -- "1" Reputation : has
Review --> Job : about
Review --> UserProfile : from reviewer
Review --> UserProfile : to reviewee

' Notes
note right of Job
  <b>JobStatus Flow:</b>
  Open → InProgress → Completed
  Or: Open → Cancelled
  Or: InProgress → Disputed
end note

note right of Escrow
  <b>Payment Flow:</b>
  locked=true → funds held
  released=true → paid to freelancer
  disputed=true → voting process
end note

note right of Dispute
  <b>Resolution:</b>
  votes_for_client vs votes_for_freelancer
  Winner gets the escrow amount
end note

@enduml
